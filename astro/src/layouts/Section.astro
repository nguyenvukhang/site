---
import BaseHead from '../components/BaseHead.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'

const { class: className, outer } = Astro.props
---

<div class:list={['w-full flex justify-center', outer]}>
  <div
    class:list={['w-full sm:max-w-[52rem] px-8 sm:px-12 md:px-14', className]}
  >
    <div class="overflow-x-auto">
      <slot />
    </div>
  </div>
</div>
