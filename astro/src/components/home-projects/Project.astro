---
const { name, href, summary, text } = Astro.props
---

<a href={href} class="no-underline">
  <div
    class="-mx-3 px-3 py-2 hover:bg-selection/40 flex sm:flex-row flex-col w-full cursor-pointer"
  >
    <div class="sm:w-1/3 mr-4 font-semibold">
      {name}
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="inline text-neutral-400"
      >
        <line x1="7" y1="17" x2="17" y2="7"></line><polyline
          points="7 7 17 7 17 17"></polyline></svg
      >
    </div>
    <div class="sm:w-2/3">
      <div>{summary}</div>
      <div class="text-sm text-fg3">{text}</div>
    </div>
  </div>
</a>
