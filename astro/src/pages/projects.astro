---
import ProjectLayout from '../layouts/Project.astro'
import { getCollection } from 'astro:content'
import MainLayout from '../layouts/Main.astro'
import Section from '../layouts/Section.astro'
import { toAnchorId } from '../utils'

const collection = await getCollection('projects')
const projects = await Promise.all(
  collection.map((v) =>
    v.render().then((render) => {
      v.Content = render.Content
      delete v.render
      return v
    })
  )
)
---

<MainLayout>
  <!-- Table of contents -->
  <Section outer='bg-slate-800' class='py-8'>
    <div class="grid grid-cols-2">
      {
        projects
          .map((v) => v.data)
          .map(({ title }) => (
            <div>
              <a href={toAnchorId(title, '#')} class='text-white'>{title}</a>
            </div>
          ))
      }
    </div>
  </Section>

  <!-- Project summaries -->
  <Section class="sm:max-w-[64rem]">
    {
      projects.map(({ Content, data }) => (
        <ProjectLayout {...data}>
          <Content />
        </ProjectLayout>
      ))
    }
  </Section>
</MainLayout>
